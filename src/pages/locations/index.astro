---
/**
 * /locations — hub page listing every city served.
 *
 * Breadcrumb parent for city pages and a crawl hub linking to all of them.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import { locations } from '../../data/locations';
import { cityUrl } from '../../lib/urls';

const links = locations.map((loc) => ({
  label: `${loc.city}, ${loc.region}`,
  href: cityUrl(loc.slug),
}));
---

<BaseLayout
  title="Service Areas"
  description="Load Logic Junk Removal serves Mesa and the East Valley — Chandler, Gilbert, Tempe, Queen Creek, San Tan Valley, Apache Junction, Gold Canyon, Scottsdale, and Ahwatukee."
>
  <div class="container page">
    <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Service Areas' }]} />
    <header class="page-hero">
      <h1>Service Areas</h1>
      <p class="lede">Mesa-based crews serving the entire East Valley, with fast scheduling in every city.</p>
    </header>
    <InternalLinks title="Cities we serve" links={links} />
  </div>
</BaseLayout>
