---
/**
 * /locations — hub page listing every city served.
 *
 * Breadcrumb parent for city pages and a crawl hub linking to all of them.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import { serviceAreaLocations } from '../../lib/links';
import { cityUrl } from '../../lib/urls';

// Only surrounding service areas — the home market (Mesa) lives on the homepage.
const links = serviceAreaLocations.map((loc) => ({
  label: `${loc.city}, ${loc.region}`,
  href: cityUrl(loc.slug),
}));
---

<BaseLayout
  title="Areas We Serve"
  description="Beyond our home base in Mesa, Load Logic Junk Removal serves the East Valley — Chandler, Gilbert, Tempe, Queen Creek, San Tan Valley, Apache Junction, Gold Canyon, Scottsdale, and Ahwatukee."
>
  <div class="container page">
    <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Areas We Serve' }]} />
    <header class="page-hero">
      <h1>Areas We Serve</h1>
      <p class="lede">
        Load Logic is based in Mesa and serves the surrounding East Valley. Looking for Mesa junk
        removal? That is right here on our <a href="/services">services</a> pages.
      </p>
    </header>
    <InternalLinks title="Surrounding cities we serve" links={links} />
  </div>
</BaseLayout>
