---
/**
 * /locations/[city] — dynamic route generating ONE page per city.
 *
 * getStaticPaths() fans out over the locations catalog. Add a city to
 * data/locations.ts and its page (plus its location-service pages) appears.
 */
import CityLayout from '../../../layouts/CityLayout.astro';
import { serviceAreaLocations } from '../../../lib/links';

export function getStaticPaths() {
  // serviceAreaLocations excludes the home-market city (Mesa), so no
  // /locations/mesa-az page is ever generated.
  return serviceAreaLocations.map((location) => ({
    params: { city: location.slug },
    props: { location },
  }));
}

const { location } = Astro.props;
---

<CityLayout {location} />
