---
/**
 * /locations/[city]/[service] — city × category page (moved into a folder so
 * location sub-service routes can nest at /locations/[city]/[service]/[subservice]).
 *
 * getStaticPaths() produces the cartesian product of every location and the
 * categories it offers, skipping combinations a city doesn't serve (req #9).
 */
import LocationServiceLayout from '../../../../layouts/LocationServiceLayout.astro';
import { serviceAreaLocations, servicesForLocation } from '../../../../lib/links';

export function getStaticPaths() {
  // Iterate service-area cities only (home-market Mesa is excluded), so no
  // /locations/mesa-az/[service] pages are generated.
  return serviceAreaLocations.flatMap((location) =>
    servicesForLocation(location).map((service) => ({
      params: { city: location.slug, service: service.slug },
      props: { location, service },
    })),
  );
}

const { location, service } = Astro.props;
---

<LocationServiceLayout {location} {service} />
