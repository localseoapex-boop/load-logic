---
/**
 * /services — hub page listing every service.
 *
 * Acts as the breadcrumb parent for service pages and a crawl hub that links to
 * all of them, helping search engines discover the full set.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import { services } from '../../data/services';
import { serviceUrl } from '../../lib/urls';

const links = services.map((s) => ({
  label: s.name,
  href: serviceUrl(s.slug),
  description: s.tagline,
}));
---

<BaseLayout
  title="Junk Removal & Cleanout Services"
  description="Explore Load Logic's full range of junk removal and cleanout services across Mesa and the East Valley — furniture, appliances, garages, estates, and more."
>
  <div class="container page">
    <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Services' }]} />
    <header class="page-hero">
      <h1>Junk Removal &amp; Cleanout Services</h1>
      <p class="lede">Full-service hauling for homes and businesses across Mesa and the East Valley — we bring the truck and the muscle.</p>
    </header>
    <InternalLinks title="Browse services" links={links} />
  </div>
</BaseLayout>
