---
/**
 * InternalLinks.astro — a titled grid of internal links (requirement #4).
 *
 * The single presentational component behind every cross-linking block:
 * "Related services", "Nearby cities", "Available in these areas". Templates
 * compute the links with the lib/links helpers and hand them here, so the
 * markup/styling of link blocks lives in exactly one place.
 *
 * Renders nothing when there are no links, so templates can call it
 * unconditionally.
 */
export interface LinkItem {
  label: string;
  href: string;
  description?: string;
}

interface Props {
  title: string;
  links: LinkItem[];
}

const { title, links } = Astro.props;
---

{
  links.length > 0 && (
    <section class="internal-links">
      <h2>{title}</h2>
      <ul>
        {links.map((link) => (
          <li>
            <a href={link.href}>{link.label}</a>
            {link.description && <p>{link.description}</p>}
          </li>
        ))}
      </ul>
    </section>
  )
}

<style>
  .internal-links {
    margin-top: 2.5rem;
  }
  .internal-links h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }
  .internal-links ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
  }
  .internal-links li {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0.85rem 1rem;
    transition: border-color 0.2s, transform 0.15s ease;
  }
  .internal-links li:hover {
    border-color: var(--green);
    transform: translateY(-2px);
  }
  .internal-links a {
    font-weight: 700;
    text-decoration: none;
    color: var(--green-dark);
  }
  .internal-links p {
    margin: 0.25rem 0 0;
    font-size: 0.875rem;
    color: var(--muted);
  }
</style>
