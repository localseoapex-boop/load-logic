---
/**
 * CityLayout.astro — template for /locations/[city] pages.
 *
 * Data-driven from a Location object. Builds the city hero, breadcrumbs, unique
 * local intro + neighborhoods, the list of services available in that city (each
 * linking to the dedicated location-service page), and nearby-city links. The
 * serving office's phone is resolved via officeId so the CTA is locally relevant.
 */
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import InternalLinks from '../components/InternalLinks.astro';
import { BUSINESS } from '../config/site';
import type { Location } from '../data/locations';
import { getOffice, primaryOffice } from '../data/offices';
import { servicesForLocation, nearbyCities } from '../lib/links';
import { cityUrl, locationServiceUrl } from '../lib/urls';

interface Props {
  location: Location;
}

const { location } = Astro.props;
const office = getOffice(location.officeId) ?? primaryOffice;
const cityState = `${location.city}, ${location.region}`;

const title = `Junk Removal in ${cityState}`;
const description = `Junk removal and cleanouts in ${cityState} — furniture, appliances, mattresses, garages, estates, and construction debris, with upfront pricing.`;

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Areas We Serve', href: '/locations' },
  { name: cityState },
];

// Services this city offers -> deep links to the location-service combo pages.
const serviceLinks = servicesForLocation(location).map((s) => ({
  label: `${s.name} in ${location.city}`,
  href: locationServiceUrl(location.slug, s.slug),
  description: s.tagline,
}));

// Nearby cities for lateral internal linking.
const nearbyLinks = nearbyCities(location.slug).map((loc) => ({
  label: `Junk removal in ${loc.city}, ${loc.region}`,
  href: cityUrl(loc.slug),
}));
---

<BaseLayout {title} {description}>
  <article class="container page">
    <Breadcrumbs items={crumbs} />

    <header class="page-hero">
      <p class="eyebrow">Serving {cityState}</p>
      <h1>{title}</h1>
      <p class="lede">{location.intro ?? description}</p>
      <div class="hero-actions">
        <a class="button primary" href={`tel:${office.phone}`}>Get a free quote — {BUSINESS.phoneDisplay}</a>
        <a class="button outline" href="/services">View all services</a>
      </div>
    </header>

    <div class="page-body">
      <p>
        Load Logic is a Mesa-based junk removal team serving {location.city} and the surrounding East
        Valley. We bring the truck and the muscle, give you an upfront price before we load, and clean
        up the area when the job is done — no dumpster rental, no heavy lifting on your end.
      </p>
      {location.neighborhoods && location.neighborhoods.length > 0 && (
        <p class="areas-line">
          <strong>Areas we serve in {location.city}:</strong> {location.neighborhoods.join(' · ')}
        </p>
      )}
    </div>

    <InternalLinks title={`Services in ${location.city}`} links={serviceLinks} />
    <InternalLinks title="Nearby areas we serve" links={nearbyLinks} />

    <section class="cta-band">
      <div>
        <h2>Need junk gone in {location.city}?</h2>
        <p>Call or send a few photos for a fast, upfront quote.</p>
      </div>
      <a class="button primary" href={`tel:${office.phone}`}>Call {BUSINESS.phoneDisplay}</a>
    </section>
  </article>
</BaseLayout>
